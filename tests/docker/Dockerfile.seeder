FROM rust:1.82-slim AS builder

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY tests/docker/data-seeder/ ./

RUN cargo build --release && \
    strip target/release/data-seeder

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/data-seeder /usr/local/bin/data-seeder

ENTRYPOINT ["data-seeder"]
